    "conceptGu": "Binary = base-2. Computer transistors = ON(1) or OFF(0). Bedtime story reinforce: electricity = switch. Each bit = position value (1,2,4,8). Right to left doubles.",
    "conceptEn": "Binary is base-2. Each bit position doubles in value left to right.",
    "storyGu": "'4 bulbs — right bulb = 1, next = 2, next = 4, next = 8. ON karo 1 + 2 = 3. Computer exactly same! Phone number, photo, music — all stored as ON/OFF bulbs!'",
    "scriptGu": "'Ready for secret code? 0101 = ? 4+1=5! Only computer scientists know this!'",
    "vocab": [
      {"gu": "Bit = 1 switch", "en": "Bit"},
      {"gu": "ON = 1 = electricity", "en": "Binary 1"},
      {"gu": "OFF = 0 = no electricity", "en": "Binary 0"},
      {"gu": "Binary = બે-base number", "en": "Binary"}
    ],
    "tipsGu": "💡 Light switches demo! 4 switches, assign values 8,4,2,1. Flip and calculate together physically!"
  },
