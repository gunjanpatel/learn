      "options": [
        {"gu": "ફક્ત A = 1", "en": "Only A is 1"},
        {"gu": "ફક્ત B = 1", "en": "Only B is 1"},
        {"gu": "A AND B બંને = 1", "en": "BOTH A and B = 1"},
        {"gu": "બંને = 0", "en": "Both = 0"}
      ],
      "answer": 2,
      "hintGu": "AND = BOTH! Book AND pencil — બંને જ!",
      "hintEn": "AND means BOTH must be true!"
    },
