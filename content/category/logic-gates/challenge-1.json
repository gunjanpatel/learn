  "trophy": {"icon": "⚡", "nameGu": "Gate Keeper", "nameEn": "Gate Keeper"},
  "teacherGuide": {
    "conceptGu": "Logic gate = decision maker circuit. AND = બંને true. OR = ઓછામાં ઓછું એક. NOT = flip. CPU = billions of gates!",
    "storyGu": "'Phone unlock: face match AND correct angle — AND gate! Door: password OR fingerprint — OR gate!'",
    "scriptGu": "'Yuval, school bag ready? Book inside AND pencil inside? BOTH = yes = AND gate!'",
    "vocab": [
      {"gu": "AND = બંને TRUE", "en": "AND gate"},
      {"gu": "OR = ઓછામાં ઓછું એક", "en": "OR gate"},
      {"gu": "NOT = ઉલટું flip", "en": "NOT gate"},
      {"gu": "Output = result", "en": "Output"}
    ],
    "tipsGu": "💡 TV on: power AND remote = AND gate! Torch: press OR shake = OR gate!"
  },
  "questions": [
    {
